---
import "../styles/global.css";
import Playground from "../components/Playground";
import { content, desktopApps, heroObjects, profile } from "../data/profile";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Chris Williams' personal homepage. Frenchies, golf, whiskey, and small things I build. Drag the toys, open the windows."
    />
    <meta name="theme-color" content="#ffd21f" />
    <title>{profile.name} | Personal Homepage</title>
  </head>
  <body>
    <Playground
      profile={profile}
      heroObjects={heroObjects}
      desktopApps={desktopApps}
      content={content}
      client:load
    />
  </body>
</html>
